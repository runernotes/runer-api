PORT=:8080
ENV=development

# Generate a strong random secret for production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production
JWT_TOKEN_DURATION=1h
JWT_REFRESH_TOKEN_DURATION=720h
MAGIC_LINK_TOKEN_DURATION=1h

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runer_notes
DATABASE_LOG_LEVEL=warn
DATABASE_MAX_IDLE_CONNS=10
DATABASE_MAX_OPEN_CONNS=100
DATABASE_CONN_MAX_LIFETIME=1h

APP_BASE_URL=http://localhost:8080

# Subscription / quota
FREE_NOTE_LIMIT=50

# Email (leave RESEND_API_KEY empty to use console logging in development)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
